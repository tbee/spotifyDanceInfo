FROM eclipse-temurin:25-jre-alpine

# Create non-root user (UID/GID 1000) - recommended for security
RUN addgroup -g 1000 appgroup && \
    adduser -D -u 1000 -G appgroup appuser

# Create directories
RUN mkdir -p /app /data /data-init && \
    chown -R appuser:appgroup /app /data /data-init

# Populate data
COPY --chown=appuser:appgroup --chmod=0644 src/main/container/application-default.properties /data/
COPY --chown=appuser:appgroup --chmod=0644 src/main/container/config.tecl /data/
COPY --chown=appuser:appgroup --chmod=0644 src/main/container/logback.xml /data/

# Populate app
COPY --chown=appuser:appgroup --chmod=0644 target/*-boot.jar /app/app.jar

WORKDIR /data
USER appuser
EXPOSE 8080
EXPOSE 5005

# Default command
CMD ["java", "-Dlogging.config=/data/logback.xml", "-Dlogback.statusListenerClass=ch.qos.logback.core.status.OnConsoleStatusListener", "-agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=*:5005", "-jar", "/app/app.jar"]
